---
import AuthLayout from "../layouts/AuthLayout.astro";
---

<AuthLayout title="Login">
  <section class="auth-card">
    <h1>Entrar</h1>

    <form id="login-form" class="form">
      <label>
        E-mail
        <input type="email" id="email" required />
      </label>

      <label>
        Senha
        <input type="password" id="password" required />
      </label>

      <button type="submit">Entrar</button>
    </form>

    <p style="margin-top: 12px;">
      <a href="/register">Criar conta</a>
    </p>

    <pre id="login-result" class="result-box"></pre>
  </section>

  <script>
    import { login, saveToken } from "../lib/auth";

    const form = document.getElementById("login-form") as HTMLFormElement | null;
    const result = document.getElementById("login-result") as HTMLPreElement | null;

    function setResult(message: string) {
      if (result) {
        result.textContent = message;
      }
    }

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();

      const emailInput = document.getElementById("email") as HTMLInputElement | null;
      const passwordInput = document.getElementById("password") as HTMLInputElement | null;

      if (!emailInput || !passwordInput) {
        setResult("Campos do formulário não encontrados.");
        return;
      }

      const email = emailInput.value.trim();
      const password = passwordInput.value;

      if (!email || !password) {
        setResult("Informe e-mail e senha.");
        return;
      }

      setResult("Entrando...");

      try {
        const data = await login(email, password);

        if (!data || typeof data !== "object" || !("token" in data) || !data.token) {
          setResult(`Resposta inválida da API: ${JSON.stringify(data)}`);
          return;
        }

        saveToken(String(data.token));
        window.location.href = "/organizations";
      } catch (error) {
        setResult(`Erro no login: ${String(error)}`);
      }
    });
  </script>
</AuthLayout>