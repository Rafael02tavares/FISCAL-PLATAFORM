---
import AppLayout from "../layouts/Layout.astro";
---

<AppLayout title="Dashboard">
  <section class="page-header">
    <h1>Dashboard</h1>
    <p>Visão geral da operação fiscal.</p>
  </section>

  <section class="stats-grid">
    <div class="stat-card">
      <div class="stat-label">Notas importadas</div>
      <div class="stat-value" id="stat-invoices">--</div>
    </div>

    <div class="stat-card">
      <div class="stat-label">Empresa ativa</div>
      <div class="stat-value" id="stat-organization">--</div>
    </div>

    <div class="stat-card">
      <div class="stat-label">Status da API</div>
      <div class="stat-value" id="stat-api">--</div>
    </div>
  </section>

  <section class="panel">
    <h2>Ações rápidas</h2>
    <div class="actions">
      <a class="button-link" href="/upload">Importar XML</a>
      <a class="button-link" href="/invoices">Ver notas</a>
      <a class="button-link" href="/organizations">Trocar empresa</a>
    </div>
  </section>

  <section class="panel" style="margin-top: 20px;">
    <h2>Resumo</h2>
    <div id="dashboard-result">Carregando dados...</div>
  </section>

  <script>
    import { listInvoices } from "../lib/invoices";
    import { listOrganizations } from "../lib/organizations";

    const statInvoices = document.getElementById("stat-invoices") as HTMLDivElement | null;
    const statOrganization = document.getElementById("stat-organization") as HTMLDivElement | null;
    const statAPI = document.getElementById("stat-api") as HTMLDivElement | null;
    const result = document.getElementById("dashboard-result") as HTMLDivElement | null;

    interface Invoice {
      id: string;
      number: string;
      series: string;
      emitter_name: string;
      issued_at: string;
      total_amount: string;
      status: string;
    }

    interface Organization {
      id: string;
      name: string;
      cnpj: string;
      role?: string;
    }

    async function loadDashboard() {
      const token = localStorage.getItem("token");
      const organizationId = localStorage.getItem("organization_id");

      if (!token) {
        window.location.href = "/login";
        return;
      }

      if (!organizationId) {
        window.location.href = "/organizations";
        return;
      }

      try {
        if (statAPI) statAPI.textContent = "Online";

        const [invoiceData, organizationData] = await Promise.all([
          listInvoices(),
          listOrganizations(),
        ]);

        const invoices: Invoice[] = invoiceData.invoices || [];
        const organizations: Organization[] = organizationData.organizations || [];

        const activeOrganization =
          organizations.find((org) => org.id === organizationId) || null;

        if (statInvoices) {
          statInvoices.textContent = String(invoices.length);
        }

        if (statOrganization) {
          statOrganization.textContent = activeOrganization?.name || "Não encontrada";
        }

        if (!result) return;

        const latestInvoices = invoices.slice(0, 5);

        if (latestInvoices.length === 0) {
          result.innerHTML = `
            <p>Nenhuma nota importada ainda.</p>
            <p>Use o menu lateral para importar um XML.</p>
          `;
          return;
        }

        const rows = latestInvoices
          .map(
            (invoice: Invoice) => `
              <tr>
                <td>${invoice.number}</td>
                <td>${invoice.series}</td>
                <td>${invoice.emitter_name}</td>
                <td>${invoice.issued_at}</td>
                <td>${invoice.total_amount}</td>
                <td>${invoice.status}</td>
                <td><a href="/invoices/${invoice.id}">Ver</a></td>
              </tr>
            `
          )
          .join("");

        result.innerHTML = `
          <table class="table">
            <thead>
              <tr>
                <th>Número</th>
                <th>Série</th>
                <th>Emitente</th>
                <th>Data</th>
                <th>Total</th>
                <th>Status</th>
                <th>Ação</th>
              </tr>
            </thead>
            <tbody>${rows}</tbody>
          </table>
        `;
      } catch (error) {
        if (statAPI) statAPI.textContent = "Erro";

        if (result) {
          result.textContent = `Erro ao carregar dashboard: ${String(error)}`;
        }
      }
    }

    loadDashboard();
  </script>
</AppLayout>