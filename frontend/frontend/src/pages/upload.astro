---
import AppLayout from "../layouts/Layout.astro";
---

<AppLayout title="Importar XML">
  <section class="page-header">
    <h1>Importar XML</h1>
    <p>Envie o XML da NF-e para análise e aprendizado fiscal.</p>
  </section>

  <section class="panel">
    <form id="upload-form" class="form">
      <label>
        Arquivo XML
        <input type="file" id="xml-file" name="file" accept=".xml" required />
      </label>

      <button type="submit">Enviar XML</button>
    </form>

    <pre id="upload-result" class="result-box" style="margin-top: 16px;"></pre>
  </section>

  <script>
    const form = document.getElementById("upload-form") as HTMLFormElement | null;
    const result = document.getElementById("upload-result") as HTMLPreElement | null;

    function setResult(message: string) {
      if (result) {
        result.textContent = message;
      }
    }

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();

      const token = localStorage.getItem("token");
      const organizationId = localStorage.getItem("organization_id");

      if (!token) {
        window.location.href = "/login";
        return;
      }

      if (!organizationId) {
        window.location.href = "/organizations";
        return;
      }

      const fileInput = document.getElementById("xml-file") as HTMLInputElement | null;

      if (!fileInput || !fileInput.files || fileInput.files.length === 0) {
        setResult("Selecione um arquivo XML.");
        return;
      }

      const formData = new FormData();
      formData.append("file", fileInput.files[0]);

      setResult("Enviando XML...");

      try {
        const response = await fetch("http://localhost:8081/invoices/upload", {
          method: "POST",
          headers: {
            Authorization: `Bearer ${token}`,
            "X-Organization-ID": organizationId,
          },
          body: formData,
        });

        const contentType = response.headers.get("content-type") || "";
        const isJSON = contentType.includes("application/json");

        if (!response.ok) {
          const errorBody = isJSON ? await response.json() : await response.text();
          throw new Error(typeof errorBody === "string" ? errorBody : JSON.stringify(errorBody));
        }

        const data = isJSON ? await response.json() : await response.text();

        if (!data || typeof data !== "object" || !("invoice_id" in data)) {
          setResult(`Resposta inesperada da API: ${JSON.stringify(data)}`);
          return;
        }

        setResult("XML importado com sucesso. Redirecionando...");

        setTimeout(() => {
          window.location.href = `/invoices/${data.invoice_id}`;
        }, 800);
      } catch (error) {
        setResult(`Erro ao enviar XML: ${String(error)}`);
      }
    });
  </script>
</AppLayout>