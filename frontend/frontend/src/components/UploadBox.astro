---
---
<section class="upload-box">
    <h2>Importar XML da NF-e</h2>
    <form id="upload-form" class="upload-form">
      <input type="file" id="xml-file" name="file" accept=".xml" />
      <button type="submit">Enviar XML</button>
    </form>
  
    <pre id="upload-result" class="result-box"></pre>
  </section>
  
  <script>
    const form = document.getElementById("upload-form") as HTMLFormElement | null;
    const result = document.getElementById("upload-result") as HTMLPreElement | null;
  
    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
  
      const fileInput = document.getElementById("xml-file") as HTMLInputElement | null;
      const token = localStorage.getItem("token");
      const organizationId = localStorage.getItem("organization_id");
  
      if (!fileInput || !fileInput.files || fileInput.files.length === 0) {
        if (result) {
          result.textContent = "Selecione um arquivo XML.";
        }
        return;
      }
  
      if (!token || !organizationId) {
        if (result) {
          result.textContent = "Token ou organization não encontrados.";
        }
        return;
      }
  
      const formData = new FormData();
      formData.append("file", fileInput.files[0]);
  
      try {
        const response = await fetch("http://localhost:8081/invoices/upload", {
          method: "POST",
          headers: {
            Authorization: `Bearer ${token}`,
            "X-Organization-ID": organizationId,
          },
          body: formData,
        });
  
        const contentType = response.headers.get("content-type") || "";
  
        if (contentType.includes("application/json")) {
          const data = await response.json();
          if (result) {
            result.textContent = JSON.stringify(data, null, 2);
          }
        } else {
          const text = await response.text();
          if (result) {
            result.textContent = text;
          }
        }
      } catch (error) {
        if (result) {
          result.textContent = `Erro ao enviar XML: ${String(error)}`;
        }
      }
    });
  </script>