---
interface Invoice {
  id: string
  number: string
  series: string
  emitter_name: string
  issued_at: string
  total_amount: string
  status: string
}

interface Props {
  invoices?: Invoice[]
}

const { invoices = [] } = Astro.props as Props
---

<table class="table">
  <thead>
    <tr>
      <th>Número</th>
      <th>Série</th>
      <th>Emitente</th>
      <th>Data</th>
      <th>Total</th>
      <th>Status</th>
      <th>Ação</th>
    </tr>
  </thead>
  <tbody>
    {invoices.map((invoice) => (
      <tr>
        <td>{invoice.number}</td>
        <td>{invoice.series}</td>
        <td>{invoice.emitter_name}</td>
        <td>{invoice.issued_at}</td>
        <td>{invoice.total_amount}</td>
        <td>{invoice.status}</td>
        <td>
          <a href={`/invoices/${invoice.id}`}>Ver</a>
        </td>
      </tr>
    ))}
  </tbody>
</table>